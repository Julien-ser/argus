# Copy this file to .env and fill in your values.
# The backend loads variables from backend/.env at startup (or from the shell environment).

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Required for LLM-enhanced suggestions (GET /projects/suggestions).
# Free account + key at https://openrouter.ai/keys
# The model used is baidu/cobuddy:free — no credits needed.
OPENROUTER_API_KEY=

# ── Backend ───────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on (default 7777).
# ARGUS_PORT=7777

# Path to the SQLite database file (default: argus.db in project root).
# ARGUS_DB_PATH=../argus.db
